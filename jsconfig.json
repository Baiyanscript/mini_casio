{
    "compilerOptions": {
      "target": "ES6",
      "module": "commonjs",
      "allowSyntheticDefaultImports": true,
      "baseUrl": "./",
      "paths": {
        "@/*": ["*"],
        "@common/*": ["common/*"]
      }
    },
    "include": [
      "**/*.js",
      "**/*.ux"
    ],
    "exclude": [
      "node_modules",
      "build"
    ]
  }